# Local operational config for a deployed marble-server device.
# Copy to config/moon.env and fill in the private/live values for your setup.

MOON_HOSTNAME=moon
MOON_OPENSSH_USER=user
MOON_OPENSSH_PORT=2222
MOON_LAN_HOST=192.0.2.10
MOON_TAILNET_HOST=moon.example-tailnet.ts.net
MOON_TAILNET_DOMAIN=example-tailnet.ts.net
MOON_TAILNET_ACCOUNT=you@example.com
MOON_SSH_IDENTITY_FILE=~/.ssh/moon_ed25519
MOON_ADB_SERIAL=device-serial
MOON_MAC_TAILSCALE_NAME=workstation-name
