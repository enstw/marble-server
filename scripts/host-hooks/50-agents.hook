#!/bin/sh
# 50-agents.hook — TEMPLATE: launch your AI agents inside the chroot at boot.
#
# Dispatched by ksu-moon-ssh/service.sh inside the chroot; runs as ROOT, last —
# so an agent failing to boot can't mask an sshd/tailscale regression in the
# exit code service.sh reports.
#
# This file ships as a TEMPLATE: every agent line is commented out, so it does
# nothing until you uncomment an example or add your own. It is also deployed
# DISABLED (50-agents.hook.disabled). Two switches, both yours:
#   1. uncomment / add the agent lines you want, then
#   2. enable the hook:
#        sudo mv /etc/host-hooks/50-agents.hook.disabled /etc/host-hooks/50-agents.hook
#      (rename back, or `rm`, to kill.)
#
# Pattern — one line per agent:
#   run-as <user> -- tmux-service <name> -- <start-cmd> [args...]
#
#   run-as        drop root -> the owning user (su -l <user> -s /bin/sh -c …;
#                 gives the agent a clean login env + the user's PATH). See
#                 scripts/run-as.sh.
#   tmux-service  supervise it: named detached tmux session, while-true crash
#                 loop, log tee to ~/.local/state/moon-agents/<name>.log. The
#                 chroot has no systemd, so this is the "unit". See
#                 scripts/tmux-service.sh.
#
# Requires agents_setup.sh to have installed tmux-service + run-as and the
# per-agent toolchains (Node 24, uv). Attach to a running agent over ssh:
#   ssh moon-user -t tmux attach -t <name>
set -e

# --- Generic example ---------------------------------------------------------
# run-as user -- tmux-service myagent -- myagent serve --port 9000

# --- FreelOAder (example) ----------------------------------------------------
# Local OpenAI-compatible proxy in front of the claude/codex CLIs. Start it
# BEFORE any agent whose ~/.hermes/config.yaml base_url points at it
# (http://127.0.0.1:8000/v1), so the gateway is listening on the first turn.
# `cd` is load-bearing (relative .venv + cwd-resolved freeloader.toml);
# create_default_app is a factory, hence --factory. Full gotchas:
# docs/INSTALLATION.md § "Configuring which agents start".
# run-as user -- tmux-service freeloader -- sh -c 'cd /home/user/freeloader && exec .venv/bin/uvicorn freeloader.server:create_default_app --factory --host 127.0.0.1 --port 8000'

# --- Hermes Agent gateway (example) ------------------------------------------
# Foreground `gateway run` (NOT `gateway install` / `start` — those want a
# systemd-user unit this chroot doesn't have). --replace clears a stale hermes
# from a prior boot before binding the gateway socket. Full gotchas:
# docs/INSTALLATION.md § "Configuring which agents start".
# run-as user -- tmux-service hermes -- hermes gateway run --replace

# --- OpenClaw (example) ------------------------------------------------------
# run-as user -- tmux-service openclaw -- openclaw gateway --port 18789

# --- Your agents below -------------------------------------------------------
